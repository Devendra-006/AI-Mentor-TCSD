{
  "webDev": {
    "title": "Web Development",
    "steps": [
      {
        "id": 1,
        "title": "Learn HTML Basics",
        "description": "Understand tags, forms, tables, and semantic HTML",
        "resources": [
          { "label": "MDN HTML Guide", "url": "https://developer.mozilla.org/en-US/docs/Web/HTML" },
          { "label": "FreeCodeCamp HTML", "url": "https://www.freecodecamp.org/learn/2022/responsive-web-design/" }
        ]
      },
      {
        "id": 2,
        "title": "Master CSS Fundamentals",
        "description": "Learn box model, flexbox, grid, and responsive design",
        "resources": [
          { "label": "CSS Tricks - Flexbox", "url": "https://css-tricks.com/snippets/css/a-guide-to-flexbox/" },
          { "label": "CSS Grid Garden", "url": "https://cssgridgarden.com/" }
        ]
      },
      {
        "id": 3,
        "title": "JavaScript Essentials",
        "description": "Variables, functions, DOM manipulation, async programming",
        "resources": [
          { "label": "JavaScript.info", "url": "https://javascript.info/" },
          { "label": "Eloquent JavaScript", "url": "https://eloquentjavascript.net/" }
        ]
      },
      {
        "id": 4,
        "title": "React.js Fundamentals",
        "description": "Components, hooks, state management, routing",
        "resources": [
          { "label": "React Official Docs", "url": "https://react.dev/" },
          { "label": "React Tutorial", "url": "https://react.dev/learn" }
        ]
      },
      {
        "id": 5,
        "title": "Backend Basics - Node.js",
        "description": "Express.js, REST APIs, middleware",
        "resources": [
          { "label": "Node.js Official", "url": "https://nodejs.org/en/learn" },
          { "label": "Express.js Guide", "url": "https://expressjs.com/en/starter/installing.html" }
        ]
      },
      {
        "id": 6,
        "title": "Database Fundamentals",
        "description": "SQL basics, MongoDB, connecting to databases",
        "resources": [
          { "label": "MongoDB University", "url": "https://learn.mongodb.com/" },
          { "label": "SQLZoo", "url": "https://sqlzoo.net/" }
        ]
      },
      {
        "id": 7,
        "title": "Version Control with Git",
        "description": "Git commands, branching, GitHub workflows",
        "resources": [
          { "label": "Git Official Docs", "url": "https://git-scm.com/doc" },
          { "label": "GitHub Skills", "url": "https://skills.github.com/" }
        ]
      },
      {
        "id": 8,
        "title": "Build Portfolio Projects",
        "description": "Create 3-5 projects to showcase your skills",
        "resources": [
          { "label": "Project Ideas", "url": "https://github.com/florinpop17/app-ideas" }
        ]
      }
    ]
  },
  "dataScience": {
    "title": "Data Science & ML",
    "steps": [
      {
        "id": 1,
