          { "label": "LeetCode SQL", "url": "https://leetcode.com/problemset/database/" }
        ]
      },
      {
        "id": 8,
        "title": "Build ML Projects",
        "description": "Complete 3-5 end-to-end ML projects",
        "resources": [
          { "label": "Kaggle Competitions", "url": "https://www.kaggle.com/competitions" },
          { "label": "ML Project Ideas", "url": "https://github.com/Niraj-Lunavat/Projects-Collection" }
        ]
      }
    ]
  },
