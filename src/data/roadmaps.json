        "resources": [
          { "label": "scikit-learn Tutorial", "url": "https://scikit-learn.org/stable/tutorial/index.html" },
          { "label": "Andrew Ng's ML Course", "url": "https://www.coursera.org/learn/machine-learning" }
        ]
      },
      {
        "id": 6,
        "title": "Deep Learning Introduction",
        "description": "Neural networks, TensorFlow or PyTorch basics",
