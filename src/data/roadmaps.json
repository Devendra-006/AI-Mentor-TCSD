          { "label": "Khan Academy - Linear Algebra", "url": "https://www.khanacademy.org/math/linear-algebra" },
          { "label": "3Blue1Brown - Essence of Linear Algebra", "url": "https://youtube.com/playlist?list=PLZHQObOWTQDPD3MizzM2xVFitgF8hE_ab" }
        ]
      },
      {
        "id": 3,
